{
  "name": "@contextos/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "knex migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.ts",
    "seed": "knex seed:run --knexfile knexfile.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@qdrant/js-client-rest": "^1.11.0",
    "bullmq": "^5.12.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.0",
    "fastify": "^4.28.0",
    "ioredis": "^5.4.0",
    "knex": "^3.1.0",
    "openai": "^4.60.0",
    "pg": "^8.12.0",
    "pino": "^9.4.0",
    "tiktoken": "^1.0.16",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
